# RennOS Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Claude Code auto-loads .env on session start
# NEVER commit .env — it's in .gitignore

# === Twitter/X API ===
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
# TWITTER_BEARER_TOKEN=

# === Medium ===
# MEDIUM_TOKEN=

# === Email Service (Beehiiv/ConvertKit) ===
# EMAIL_API_KEY=

# === Google Analytics ===
# GOOGLE_ANALYTICS_ID=

# === Google Search Console ===
# GOOGLE_SEARCH_CONSOLE_KEY=

# === YouTube Data API ===
# YOUTUBE_API_KEY=
